    "chart.js": "^4.4.2",
    "pinia": "^2.1.7",
    "vue": "^3.4.19",
    "vue-draggable-plus": "^0.3.4",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.20",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/tsconfig": "^0.5.1",
    "concurrently": "^8.2.2",
    "gh-pages": "^6.3.0",
    "json-server": "^0.17.4",
    "sass": "^1.71.1",
